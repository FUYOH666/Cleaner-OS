# System Cleaner configuration
# Copy this file to config.yaml and adapt for your system

scan:
  # Paths to exclude from scanning (use ~ for home directory)
  exclude_paths:
    # macOS paths
    - ~/Library/Mail/           # macOS: mail (can be large)
    - ~/Library/Messages/       # macOS: messages (can be large)
    - ~/Library/Photos/         # macOS: photo library (can be large)
    # Linux paths
    - ~/.local/share/mail/      # Linux: mail
    - ~/.local/share/messages/  # Linux: messages
    # Exclude large dirs to speed up scanning
    - ~/.cache/Cursor/         # Cursor cache (if used)
    - ~/.config/Cursor/logs/   # Cursor logs (if used)
    # Exclude library caches (security false positives)
    - ~/.cargo/                # Rust cache (files with "token", "credentials")
    - ~/.bun/                  # Bun cache (files with "token", "password")
    - ~/.rustup/               # Rustup cache (docs with "credentials")

  # Min size in MB to include in report
  min_size_mb: 10

  # Enable security checks
  check_security: true

  # Check development project artifacts
  check_project_artifacts: true

  # Check Python dependency conflicts and unused deps
  check_dependencies: true

  # Check ML model caches (Hugging Face, PyTorch, TensorFlow)
  check_ml_cache: true

security:
  # Patterns for sensitive data files
  sensitive_patterns:
    - "*.env"
    - "*credentials*"
    - "*secret*"
    - "*password*"
    - "*token*"
    - "*api_key*"

  # Check SSH key permissions
  check_ssh_permissions: true

  # Check file permissions
  check_file_permissions: true

cleanup:
  # Patterns for files/dirs safe to delete
  safe_to_delete_patterns:
    - "**/__pycache__"      # Python bytecode cache
    - "**/.DS_Store"        # macOS metadata
    - "**/node_modules"     # Node.js deps (use with caution!)
    - "**/*.pyc"            # Compiled Python files
    - "**/.pytest_cache"    # pytest cache
    - "**/.mypy_cache"      # mypy cache
    - "**/.ruff_cache"      # ruff cache
    - "**/dist"             # Build output
    - "**/build"            # Build output
    - "**/*.egg-info"       # Python package metadata
